# Do not commit locally generated TLS material.
*.key
*.pem
*.crt

# Local and editor files.
.env
.idea/
.vscode/
*.log
node_modules/

# Generated container data if local bind mounts are used.
gitea-data/
postgres-data/
*.db
*.sqlite
*.sqlite3

# Generated test, coverage, and security reports.
reports/
app/reports/
coverage/
app/coverage/

# Local SonarQube credentials, scanner work, data, and evidence exports.
.scannerwork/
.sonar/
sonarqube-data/
sonar-postgres-data/
sonarqube-extensions/
sonarqube-logs/
evidence/Q8-initial-sonarqube-scan/results/*.token
