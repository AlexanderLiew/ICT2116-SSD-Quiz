  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "selenium-webdriver": "^4.46.0",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "diff": "8.0.3",
    "serialize-javascript": "7.0.5"
  }
