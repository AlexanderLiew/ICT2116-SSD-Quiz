{
  "name": "ict2116-ssd-quiz",
  "version": "1.0.0",
  "private": true,
  "description": "ICT2216 Q4 secure account-creation application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test:integration": "mocha --timeout 30000 tests/integration.test.js",
